---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";

interface Props {
  title: string;
  posts: CollectionEntry<"blog">[];
}

const { title, posts } = Astro.props;
---

<BaseLayout title={title} description={`Posts in the category: ${title}`}>
  <section class="mx-auto max-w-5xl py-6 md:py-12">
    <div
      class="mb-12 grid gap-6 border-b border-border/70 pb-8 md:grid-cols-[minmax(0,1.1fr)_minmax(220px,0.9fr)] md:items-end"
    >
      <div class="space-y-4">
        <p class="eyebrow">Category</p>
        <h1
          class="font-structure-title text-5xl leading-tight tracking-[-0.04em] md:text-6xl"
        >
          {title}
        </h1>
      </div>
      <p class="text-sm leading-7 text-muted-foreground md:text-base">
        All notes filed under this path, presented in the same chronological
        reading order.
      </p>
    </div>

    <ul class="list-divider">
      {
        posts.map((post) => (
          <li class="py-6 md:py-8">
            <a
              href={`/blog/${post.id}/`}
              class="group grid gap-3 md:grid-cols-[140px_minmax(0,1fr)] md:items-baseline md:gap-8"
            >
              <div class="text-sm uppercase tracking-[0.16em] text-muted-foreground">
                {post.data.pubDate.toLocaleDateString("en-US", {
                  month: "short",
                  day: "2-digit",
                  year: "numeric",
                })}
              </div>
              <div class="space-y-2">
                <h2 class="timeline-link-title font-article-title text-xl md:text-2xl">
                  {post.data.title}
                </h2>
                <p class="text-sm leading-7 text-muted-foreground md:text-base">
                  {post.data.description}
                </p>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
