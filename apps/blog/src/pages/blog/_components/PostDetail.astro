---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "@/layouts/BaseHead.astro";
import Breadcrumb from "@/components/common/Breadcrumb.astro";
import Footer from "@/layouts/Footer.astro";
import FormattedDate from "@/components/common/FormattedDate.astro";
import Header from "@/layouts/Header.astro";
import TableOfContents from "@/components/common/table-of-contents/index.astro";

type Props = CollectionEntry<"blog">["data"] & {
  id: string;
  headings: { depth: number; text: string; slug: string }[];
};

const { id, title, description, pubDate, updatedDate, heroImage, headings } =
  Astro.props;
const sectionLabel = id.includes("/")
  ? id.split("/").slice(0, -1).join(" / ")
  : "Essay";
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <style>
      .prose-editorial .astro-code {
        padding: 1.25rem;
        border-radius: 1.5rem;
        font-size: 0.92rem;
      }
    </style>
  </head>

  <body class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1 px-4 pb-16 pt-8 md:px-6 md:pb-24 md:pt-10">
      <section class="mx-auto max-w-6xl">
        <div
          class="grid gap-10 lg:grid-cols-[200px_minmax(0,1fr)_220px] lg:gap-12"
        >
          <aside class="hidden lg:block">
            <div class="sticky top-28 space-y-5 text-sm text-muted-foreground">
              <div class="space-y-2 border-b border-border/70 pb-5">
                <p class="eyebrow">Section</p>
                <p class="font-medium text-foreground/80">{sectionLabel}</p>
              </div>
              <div class="space-y-2 border-b border-border/70 pb-5">
                <p class="eyebrow">Published</p>
                <FormattedDate date={pubDate} class="text-sm" />
              </div>
              {
                updatedDate && (
                  <div class="space-y-2 border-b border-border/70 pb-5">
                    <p class="eyebrow">Updated</p>
                    <FormattedDate date={updatedDate} class="text-sm" />
                  </div>
                )
              }
            </div>
          </aside>

          <div class="min-w-0">
            <header class="fade-up border-b border-border/70 pb-8 md:pb-10">
              <Breadcrumb id={id} title={title} />
              <div class="space-y-5">
                <p class="eyebrow">{sectionLabel}</p>
                <h1
                  class="font-structure-title max-w-4xl text-4xl leading-tight tracking-[-0.04em] md:text-6xl"
                >
                  {title}
                </h1>
                <p
                  class="max-w-2xl text-base leading-8 text-muted-foreground md:text-xl md:leading-9"
                >
                  {description}
                </p>
                <div
                  class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground"
                >
                  <FormattedDate date={pubDate} />
                  {
                    updatedDate && (
                      <>
                        <span class="h-1 w-1 rounded-full bg-border" />
                        <span>
                          Updated <FormattedDate date={updatedDate} />
                        </span>
                      </>
                    )
                  }
                </div>
              </div>
            </header>

            {
              heroImage && (
                <div class="fade-up delay-1 my-10 overflow-hidden rounded-[2rem] border border-border/70 bg-secondary/40 p-2 md:my-12">
                  <Image
                    src={heroImage}
                    alt={`Hero image for ${title}`}
                    width={1020}
                    height={510}
                    class="w-full rounded-[1.4rem] object-cover"
                  />
                </div>
              )
            }

            <article class="prose-editorial fade-up delay-1 pt-2">
              <slot />
            </article>

            <div class="mt-16 border-t border-border/70 pt-8 text-center">
              <p class="eyebrow">End of note</p>
            </div>
          </div>

          <aside class="hidden lg:block">
            {
              headings && headings.length > 0 && (
                <div class="sticky top-28 rounded-[1.5rem] border border-border/70 bg-background/60 p-5 backdrop-blur-sm">
                  <TableOfContents headings={headings} />
                </div>
              )
            }
          </aside>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>
