---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<div
  class="my-8 rounded-[1.75rem] border border-border/70 px-6 py-6 md:px-8"
  style=`background-color: var(--note-bg-color); border-left: 4px solid var(--note-border-color);`
>
  <p class="mb-3 text-lg font-semibold" style=`color: var(--note-title-color);`>
    {title}
  </p>
  <div class="text-foreground/85">
    <slot />
  </div>
</div>
