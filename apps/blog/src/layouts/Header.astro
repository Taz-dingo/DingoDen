---
import HeaderLink from "@/components/common/HeaderLink.astro";
import Logo from "@/assets/logo.svg";
import ThemeToggle from "@/components/ui/ThemeToggle.tsx";
---

<header>
  <div class="site-shell site-header font-structure-title">
    <nav
      class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-4 py-4 md:px-6"
    >
      <a
        href="/blog"
        class="flex items-center gap-3 text-foreground transition-opacity duration-300 hover:opacity-100 md:gap-4"
      >
        <div class="logo-container">
          <Logo
            class="size-11 transition-transform duration-500 hover:-rotate-6 hover:scale-110 md:size-12"
          />
        </div>
        <div class="space-y-0.5">
          <p
            class="text-[0.65rem] uppercase tracking-[0.28em] text-muted-foreground"
          >
            Personal notebook
          </p>
          <h1 class="text-lg font-semibold md:text-xl">Dingo's Den</h1>
        </div>
      </a>
      <div class="flex items-center gap-2 md:gap-3">
        <HeaderLink href="/blog">Home</HeaderLink>
        <HeaderLink href="/archive">Archive</HeaderLink>
        <HeaderLink href="/about">About</HeaderLink>
        <HeaderLink href="/rss.xml">RSS</HeaderLink>
        <ThemeToggle client:load />
      </div>
    </nav>
  </div>
</header>
