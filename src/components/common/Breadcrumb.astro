---
interface Props {
  id: string;
  title: string;
}

const { id, title } = Astro.props;

const segments = id.split("/").filter(Boolean);
const breadcrumbs = [];

breadcrumbs.push({ label: "Blog", href: "/blog" });

let currentPath = "/blog";
for (const segment of segments.slice(0, -1)) {
  currentPath += `/${segment}`;
  breadcrumbs.push({ label: segment, href: currentPath });
}

breadcrumbs.push({ label: title, href: null });
---

<nav aria-label="Breadcrumb">
  <ol
    class="mb-4 flex flex-wrap items-center gap-2 text-xs uppercase tracking-[0.18em] text-muted-foreground"
  >
    {
      breadcrumbs.map((crumb, index) => (
        <li class="flex items-center gap-2">
          {crumb.href ? (
            <a href={crumb.href} class="hover:text-foreground">
              {crumb.label}
            </a>
          ) : (
            <span class="max-w-[28ch] truncate text-foreground/80">
              {crumb.label}
            </span>
          )}
          {index < breadcrumbs.length - 1 && <span class="opacity-40">/</span>}
        </li>
      ))
    }
  </ol>
</nav>
