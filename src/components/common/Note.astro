---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<aside
  class="my-10 rounded-[1.75rem] border border-border/70 px-6 py-6 md:px-8"
  style=`background-color: var(--note-bg-color);`
>
  <div class="mb-4 flex items-center gap-3">
    <span
      class="h-px w-8 shrink-0"
      style=`background-color: var(--note-border-color);`
    ></span>
    <p
      class="text-sm font-semibold uppercase tracking-[0.22em]"
      style=`color: var(--note-title-color);`
    >
      {title}
    </p>
  </div>
  <div class="space-y-4 text-foreground/85 [&_p]:my-0 [&_ul]:my-0 [&_ol]:my-0">
    <slot />
  </div>
</aside>
