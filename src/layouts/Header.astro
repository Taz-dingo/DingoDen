---
import HeaderLink from "@/components/common/HeaderLink.astro";
import Logo from "@/assets/logo.svg";
import ThemeToggle from "@/components/ui/ThemeToggle.tsx";
---

<header>
  <div class="site-shell site-header">
    <nav
      class="mx-auto flex max-w-6xl flex-col gap-3 px-4 py-3 md:flex-row md:items-center md:justify-between md:gap-6 md:px-6 md:py-4"
    >
      <a
        href="/blog"
        class="flex w-full items-center gap-3 text-foreground transition-opacity duration-300 hover:opacity-100 md:w-auto md:gap-4"
      >
        <div class="logo-container">
          <Logo
            class="size-10 transition-transform duration-500 hover:-rotate-6 hover:scale-110 md:size-12"
          />
        </div>
        <div class="space-y-0.5">
          <p
            class="text-[0.62rem] uppercase tracking-[0.24em] text-muted-foreground md:text-[0.65rem] md:tracking-[0.28em]"
          >
            Personal notebook
          </p>
          <h1 class="font-structure-title text-base font-semibold md:text-xl">
            Dingo's Den
          </h1>
        </div>
      </a>
      <div class="header-actions w-full justify-between gap-2 md:w-auto md:justify-end md:gap-3">
        <div class="header-nav-scroller">
          <HeaderLink href="/blog">Home</HeaderLink>
          <HeaderLink href="/archive">Archive</HeaderLink>
          <HeaderLink href="/about">About</HeaderLink>
          <HeaderLink href="/rss.xml">RSS</HeaderLink>
        </div>
        <ThemeToggle client:load />
      </div>
    </nav>
  </div>
</header>
